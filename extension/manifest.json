{
  "manifest_version": 3,
  "name": "FrontLine Lyrics",
  "version": "0.0.1",
 "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*"
  ],
  "action": {
    "default_icon": {
      "16": "assets/logo16.png",
      "32": "assets/logo32.png"
    },
    "default_title": "Toggle FrontLine Lyrics"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/logo16.png",
    "48": "assets/logo48.png",
    "128": "assets/logo128.png"
  }
}