{
  "manifest_version": 3,
  "name": "FrontLine Lyrics",
  "version": "1.0",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost:5000/*"
  ],
  "action": {
    "default_title": "Ligar/Desligar FrontLine Lyrics"
  },
  "background": {
    "service_worker": "background.js"
  }
}